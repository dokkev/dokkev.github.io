{% assign sidebar = site.data.blog_sidebar %}
{% assign current_url = page.url | relative_url %}

{% if sidebar %}
  <nav class="blog-sidebar sticky-top" aria-label="Blog navigation">
    {% if page.collection == 'posts' %}
      {% if page.series %}
        {% assign current_series_posts = site.posts | where: 'series', page.series %}
        {% if page.lang %}
          {% assign current_series_posts = current_series_posts | where: 'lang', page.lang %}
        {% endif %}
        {% assign current_series_posts = current_series_posts | sort: 'series_order' %}
        {% if current_series_posts.size > 0 %}
          <section class="blog-sidebar-section">
            <h2 class="blog-sidebar-heading">In This Series</h2>
            <h3 class="blog-sidebar-series-title">{{ page.series }}</h3>
            <ol class="blog-sidebar-list blog-sidebar-series-list list-unstyled">
              {% for post in current_series_posts %}
                {% assign post_href = post.url | relative_url %}
                <li>
                  <a class="blog-sidebar-link{% if post_href == current_url %} active{% endif %}" href="{{ post_href }}" {% if post_href == current_url %}aria-current="page"{% endif %}>
                    {% assign order_label = post.series_label | default: '' %}
                    {% if order_label == '' and post.series_order %}
                      {% assign order_label = post.series_order | prepend: '0' | slice: -2, 2 %}
                    {% endif %}
                    {% if order_label != '' %}
                      <span class="blog-sidebar-order">{{ order_label }}.</span>
                    {% endif %}
                    {{ post.title }}
                  </a>
                </li>
              {% endfor %}
            </ol>
          </section>
        {% endif %}
      {% else %}
        {% assign first_tag = page.tags | first %}
        <section class="blog-sidebar-section">
          <h2 class="blog-sidebar-heading">Related Notes</h2>
          <ul class="blog-sidebar-list list-unstyled">
            {% if first_tag %}
              {% assign related_count = 0 %}
              {% for post in site.posts %}
                {% if related_count >= 5 %}
                  {% break %}
                {% endif %}
                {% if post.url == page.url or post.hidden == true %}
                  {% continue %}
                {% endif %}
                {% if post.tags contains first_tag %}
                  {% assign post_href = post.url | relative_url %}
                  <li>
                    <a class="blog-sidebar-link" href="{{ post_href }}">{{ post.title }}</a>
                  </li>
                  {% assign related_count = related_count | plus: 1 %}
                {% endif %}
              {% endfor %}
              {% if related_count == 0 %}
                <li><span class="blog-sidebar-text">No closely related notes yet.</span></li>
              {% endif %}
            {% else %}
              <li><span class="blog-sidebar-text">No closely related notes yet.</span></li>
            {% endif %}
          </ul>
        </section>
      {% endif %}
    {% endif %}

    {% if sidebar.major_series and sidebar.major_series.size > 0 %}
      <section class="blog-sidebar-section">
        <h2 class="blog-sidebar-heading">Major Series</h2>
        <ul class="blog-sidebar-list list-unstyled">
          {% for item in sidebar.major_series %}
            {% assign item_url = item.url | default: '' %}
            {% assign item_href = '' %}
            {% assign series_posts = '' | split: '' %}
            {% if item.series %}
              {% assign series_posts = site.posts | where: 'series', item.series | sort: 'series_order' %}
            {% endif %}
            {% if item_url != '' %}
              {% if item_url contains '://' %}
                {% assign item_href = item_url %}
              {% else %}
                {% assign item_href = item_url | relative_url %}
              {% endif %}
            {% elsif series_posts.size > 0 %}
              {% assign first_series_post = series_posts | first %}
              {% assign item_href = first_series_post.url | relative_url %}
            {% endif %}
            <li class="blog-sidebar-major-series">
              {% if item_href != '' %}
                <a class="blog-sidebar-link{% if item_href == current_url %} active{% endif %}" href="{{ item_href }}" {% if item_href == current_url %}aria-current="page"{% endif %}>
                  {{ item.title }}
                  {% if series_posts.size > 0 %}
                    <span class="blog-sidebar-count">{{ series_posts.size }} notes</span>
                  {% endif %}
                </a>
              {% else %}
                <span class="blog-sidebar-text">{{ item.title }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}

    {% assign recent_posts = site.posts | where_exp: 'post', "post.lang != 'ko'" | where_exp: 'post', 'post.hidden != true' %}
    {% if recent_posts.size > 0 %}
      <section class="blog-sidebar-section">
        <h2 class="blog-sidebar-heading">Recent Posts</h2>
        <ul class="blog-sidebar-list blog-sidebar-recent-list list-unstyled">
          {% for post in recent_posts limit: 5 %}
            {% assign post_href = post.url | relative_url %}
            <li>
              <a class="blog-sidebar-link{% if post_href == current_url %} active{% endif %}" href="{{ post_href }}" {% if post_href == current_url %}aria-current="page"{% endif %}>
                {{ post.title }}
                <span class="blog-sidebar-date">{{ post.date | date: '%b %-d, %Y' }}</span>
              </a>
            </li>
          {% endfor %}
        </ul>
      </section>
    {% endif %}
  </nav>
{% endif %}
